template<typename MinT>
MinT min(MinT left, MinT right) {
    if (right < left) {
        return right;
    }
    return left;
}

template<typename MinCompareT>
MinCompareT min(MinCompareT& left, MinCompareT& right, bool (*comp)(const MinCompareT&, const MinCompareT&)) {
    if (comp(right, left)) {
        return right;
    }
    return left;
}

template<typename MaxT>
MaxT max(MaxT left, MaxT right) {
    if (left < right) {
        return right;
    }
    return left;
}

template<typename MaxCompareT>
MaxCompareT max(MaxCompareT& left, MaxCompareT& right, bool (*comp)(const MaxCompareT&, const MaxCompareT&)) {
    if (comp(left, right)) {
        return right;
    }
    return left;
}

template<typename FindT>
FindT *find(FindT *first, FindT *last, FindT value) {
    int length = last - first;
    for (int i = 0; i < length; i++) {
        if (first[i] == value) {
            return first + i;
        }
    }
    return last;
}

int *find(int *first, int *last, int value) {
    int length = last - first;
    for (int i = 0; i < length; i++) {
        if (first[i] == value) {
            return first + i;
        }
    }
    return last;
}

template<typename CountT>
int count(CountT *first, CountT *last, CountT value) {
    int result = 0;
    int length = last - first;
    for (int i = 0; i < length; i++) {
        if (first[i] == value) {
            result = result + 1;
        }
    }
    return result;
}

