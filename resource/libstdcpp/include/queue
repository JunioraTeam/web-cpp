template<typename T>
class priority_queue {
    vector<T> data_;

    bool less_than(T left, T right) {
        return left < right;
    }

    void swap_at(int left, int right) {
        T temp = data_[left];
        data_[left] = data_[right];
        data_[right] = temp;
    }

    void sift_up(int index) {
        while (index > 0) {
            int parent = (index - 1) / 2;
            if (!less_than(data_[parent], data_[index])) {
                return;
            }
            swap_at(parent, index);
            index = parent;
        }
    }

    void sift_down(int index) {
        int count = data_.size();
        while (1) {
            int left = index * 2 + 1;
            int right = left + 1;
            int largest = index;
            if (left < count && less_than(data_[largest], data_[left])) {
                largest = left;
            }
            if (right < count && less_than(data_[largest], data_[right])) {
                largest = right;
            }
            if (largest == index) {
                return;
            }
            swap_at(index, largest);
            index = largest;
        }
    }

public:
