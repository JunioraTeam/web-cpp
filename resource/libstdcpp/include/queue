namespace std {

template<typename V>
class priority_queue {
    V *data_;
    int size_;
    int capacity_;

    void grow() {
        int new_capacity = capacity_ * 2;
        V *new_data = new V[new_capacity];
        for (int i = 0; i < size_; i++) {
            new_data[i] = data_[i];
        }
        delete[] data_;
        data_ = new_data;
        capacity_ = new_capacity;
    }

    bool less_than(V left, V right) {
        return left < right;
    }

    void swap_at(int left, int right) {
        V temp = data_[left];
        data_[left] = data_[right];
        data_[right] = temp;
    }

    void sift_up(int index) {
        while (index > 0) {
            int parent = (index - 1) / 2;
            if (!less_than(data_[parent], data_[index])) {
                return;
            }
            swap_at(parent, index);
            index = parent;
        }
    }

    void sift_down(int index) {
        while (1) {
            int left = index * 2 + 1;
            int right = left + 1;
            int largest = index;
            if (left < size_ && less_than(data_[largest], data_[left])) {
                largest = left;
            }
            if (right < size_ && less_than(data_[largest], data_[right])) {
                largest = right;
            }
            if (largest == index) {
                return;
            }
            swap_at(index, largest);
            index = largest;
        }
    }

public:
    priority_queue() {
        size_ = 0;
        capacity_ = 4;
        data_ = new V[capacity_];
    }

    bool empty() {
        return size_ == 0;
    }

    int size() {
        return size_;
    }

    void push(V value) {
        if (size_ == capacity_) {
            grow();
        }
        data_[size_] = value;
        size_ = size_ + 1;
        sift_up(size_ - 1);
    }

    void pop() {
        if (size_ == 0) {
            __container_error("priority_queue::pop on empty priority_queue");
        }
        data_[0] = data_[size_ - 1];
        size_ = size_ - 1;
        if (size_ > 0) {
            sift_down(0);
        }
    }

    V top() {
        if (size_ == 0) {
            __container_error("priority_queue::top on empty priority_queue");
        }
        return data_[0];
    }
};

}

