#ifndef _CPP_QUEUE
#define _CPP_QUEUE

__libcall void __container_error(char *message);

namespace std {

template<typename T>
class queue {
    T *data_;
    int size_;
    int capacity_;

    void grow() {
        int new_capacity = capacity_ * 2;
        T *new_data = new T[new_capacity];
        for (int i = 0; i < size_; i++) {
            new_data[i] = data_[i];
        }
        delete[] data_;
        data_ = new_data;
        capacity_ = new_capacity;
    }

public:
    queue() {
        size_ = 0;
        capacity_ = 4;
        data_ = new T[capacity_];
    }

    bool empty() {
        return size_ == 0;
    }

    int size() {
        return size_;
    }

    void push(T value) {
        if (size_ == capacity_) {
            grow();
        }
        data_[size_] = value;
        size_ = size_ + 1;
    }

    void pop() {
        if (size_ == 0) {
            __container_error("queue::pop on empty queue");
        }
        int last = size_ - 1;
        for (int i = 0; i < last; i++) {
            data_[i] = data_[i + 1];
        }
        size_ = size_ - 1;
    }

    T& front() {
        if (size_ == 0) {
            __container_error("queue::front on empty queue");
        }
        return data_[0];
    }

    T& back() {
        if (size_ == 0) {
            __container_error("queue::back on empty queue");
        }
        return data_[size_ - 1];
    }
};

}

