#ifndef _CPP_UTILITY
#define _CPP_UTILITY

namespace std {

#ifndef _CPP_SWAP_FUNCTION
#define _CPP_SWAP_FUNCTION
template<typename SwapT>
void swap(SwapT& left, SwapT& right) {
    SwapT temp = left;
    left = right;
    right = temp;
}
#endif

void swap(int *left, int *right) {
    for (int i = 0; i < 4; i++) {
        int temp = left[i];
        left[i] = right[i];
        right[i] = temp;
    }
}

template<typename FirstT, typename SecondT>
struct pair {
    FirstT first;
    SecondT second;

    pair() {
    }

    pair(FirstT first_value, SecondT second_value) {
        first = first_value;
        second = second_value;
    }

};

pair<int, int> make_pair(int first, int second) {
    return pair<int, int>(first, second);
}

pair<double, char> make_pair(double first, char second) {
    return pair<double, char>(first, second);
}

template<typename MoveT>
MoveT& move(MoveT& value) {
    return value;
}

template<typename MoveIfNoexceptT>
MoveIfNoexceptT& move_if_noexcept(MoveIfNoexceptT& value) {
    return value;
}

template<typename DeclvalT>
DeclvalT& declval() {
    DeclvalT *ptr = 0;
    return *ptr;
}

}

#endif
